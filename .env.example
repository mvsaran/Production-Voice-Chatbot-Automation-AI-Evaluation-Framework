# OpenAI Authentication
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model Configurations
MODEL_NAME=gpt-4o
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# System Prompt
DEFAULT_SYSTEM_PROMPT="You are a helpful, friendly voice assistant. Keep your answers concise, conversational, and natural for spoken interaction."

# Audio Storage Paths
AUDIO_INPUT_DIR=audio/input
AUDIO_OUTPUT_DIR=audio/output

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=app/logs/voice_automation.log
